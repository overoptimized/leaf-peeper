---
interface Props {
  pageType?: "WebPage" | "BlogPosting" | "AboutPage" | "ContactPage" | "CollectionPage" | "TechArticle";
  title: string;
  description: string;
  canonicalURL: string;
  /** ISO date string — if omitted, looked up from page-dates.json by pathname */
  dateModified?: string;
  /** ISO date string — for BlogPosting only */
  datePublished?: string;
  /** Absolute image URL for BlogPosting */
  image?: string;
  
  /** Site configuration defaults (usually passed from a layout) */
  siteUrl?: string;
  siteName?: string;

  /** If provided, emits a SearchAction on the WebSite node. Omit if the site has no search page. */
  searchUrl?: string;
  
  /** Specific author configuration (overrides default Organization fallback) */
  authorName?: string;
  authorUrl?: string;
  authorSameAs?: string[];
  authorKnowsAbout?: Array<{ name: string; url?: string }>;
}

const {
  pageType = "WebPage",
  title,
  description,
  canonicalURL,
  dateModified,
  datePublished,
  image,
  siteUrl = Astro.site?.origin || new URL(canonicalURL).origin,
  siteName = "Website",
  searchUrl,
  authorName,
  authorUrl,
  authorSameAs = [],
  authorKnowsAbout = [],
} = Astro.props;

// Attempt to load dynamic dates if generated by the starter pack script
let dynamicDates: Record<string, string> = {};
try {
  // Use a dynamic import to avoid failing if the file doesn't exist yet
  // This will be resolved at build/runtime depending on Astro's bundler
  const datesModule = await import("../../src/data/page-dates.json");
  dynamicDates = datesModule.default || {};
} catch (e) {
  // Silent fallback
}

const pathname = new URL(canonicalURL).pathname;
// Normalise to always-trailing-slash form for dictionary lookup
const pathnameKey = pathname === "/" ? "/" : pathname.endsWith("/") ? pathname : `${pathname}/`;
const resolvedDate = dateModified ?? dynamicDates[pathnameKey] ?? null;

const WEBSITE_ID = `${siteUrl}/#website`;

let authorNode: any = null;
const AUTHOR_ID = `${siteUrl}/#author`;

if (authorName) {
  authorNode = {
    "@type": "Person",
    "@id": AUTHOR_ID,
    name: authorName,
    url: authorUrl || siteUrl,
    sameAs: authorSameAs,
  };
  if (authorKnowsAbout.length > 0) {
    authorNode.knowsAbout = authorKnowsAbout.map(k => ({
      "@type": "Thing",
      name: k.name,
      ...(k.url ? { sameAs: k.url } : {})
    }));
  }
} else {
  authorNode = {
    "@type": "Organization",
    "@id": AUTHOR_ID,
    name: siteName,
    url: siteUrl,
  };
}

const website: Record<string, unknown> = {
  "@type": "WebSite",
  "@id": WEBSITE_ID,
  name: siteName,
  url: siteUrl,
  author: { "@id": AUTHOR_ID },
};

if (searchUrl) {
  website.potentialAction = {
    "@type": "SearchAction",
    target: { "@type": "EntryPoint", urlTemplate: `${searchUrl}?q={search_term_string}` },
    "query-input": "required name=search_term_string",
  };
}

// Build the per-page node
const pageNode: Record<string, unknown> = {
  "@type": pageType,
  "@id": `${canonicalURL}#webpage`,
  url: canonicalURL,
  name: title,
  description,
  isPartOf: { "@id": WEBSITE_ID },
  author: { "@id": AUTHOR_ID },
};

if (resolvedDate) pageNode.dateModified = resolvedDate;

if (pageType === "BlogPosting" || pageType === "TechArticle") {
  pageNode.headline = title;
  if (datePublished) pageNode.datePublished = datePublished;
  if (resolvedDate && !datePublished) pageNode.datePublished = resolvedDate;
  if (image) pageNode.image = image;
  pageNode.author = { "@id": AUTHOR_ID };
}

const graph = {
  "@context": "https://schema.org",
  "@graph": [authorNode, website, pageNode],
};
---

<script type="application/ld+json" set:html={JSON.stringify(graph)} />
