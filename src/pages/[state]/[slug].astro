---
import locations from '../../data/locations.json';
import drives from '../../data/drives.json';
import phenologyData from '../../data/historical-phenology.json';
import CityHubView from '../../views/CityHubView.astro';
import LocationView from '../../views/LocationView.astro';

const { state, slug } = Astro.params;
const stateLocations = (locations as any[]).filter((l: any) => l.stateSlug === state);
const stateDrives = (drives as any[]).filter((d: any) => d.states?.includes(state));

// City hub takes priority if slug matches a citySlug in this state
const isCityHub = stateLocations.some((l: any) => l.citySlug === slug);
const locationMatch = isCityHub ? null : stateLocations.find((l: any) => l.slug === slug);

if (!isCityHub && !locationMatch) return Astro.redirect('/404');

const type = isCityHub ? 'city' : 'location';
const stateName = stateLocations[0]?.stateName || state;
const cityName = isCityHub ? stateLocations.find((l: any) => l.citySlug === slug)?.cityName : null;
---

{type === 'city' ? (
  <CityHubView
    type="city"
    stateName={stateName}
    cityName={cityName}
    citySlug={slug}
    stateLocations={stateLocations}
    stateDrives={stateDrives}
    fullPhenologyData={phenologyData}
  />
) : (
  <LocationView
    type="location"
    location={locationMatch}
    historicalPhenology={phenologyData[locationMatch!.slug]}
  />
)}
