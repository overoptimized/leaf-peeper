---
import Layout from '../../layouts/Layout.astro';
import FoliageMap from '../../components/FoliageMap';
import Sidebar from '../../components/Sidebar';
import statesGeoJSON from '../../data/us-states.json';

const schema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "2026 Fall Foliage Live Map",
  "description": "Explore real-time fall foliage maps and find the best fall color in 2026.",
  "url": "https://www.leafpeeper.com/fall-foliage-map"
};
---

<Layout 
  title="Fall Foliage Map 2026: Live Interactive Map" 
  description="Explore the live 2026 Fall Foliage Map. Check peak timing, color reports, and reliable forecasts."
  fullScreen={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <main style="position: relative; width: 100%; height: 100%; overflow: hidden; background-color: #0b0f19;">
    <h1 style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0;">
      Fall Foliage Live Map
    </h1>
    <FoliageMap client:only="react" statesGeoJSON={statesGeoJSON} />
    <Sidebar client:load />
  </main>
</Layout>
