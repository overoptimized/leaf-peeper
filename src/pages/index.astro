---
import Layout from '../layouts/Layout.astro';
import FoliageMap from '../components/FoliageMap';
import usStates from '../data/us-states.json';
---

<Layout 
  title="Leaf Peeper | Fall Foliage Tracker" 
  description="Get real-time fall foliage updates and find the best fall color with our interactive map. Plan your fall trip today!"
  fullScreen={false}
>
  <main style="width: 100%; position: relative; background: #fff; color: #333;">
    
    {/* HERO SECTION */}
    <div style="position: relative; width: 100%; height: 85vh; min-height: 600px; display: flex; align-items: center; justify-content: center; background-image: url('https://images.unsplash.com/photo-1507371341162-763b5e419408?q=80&w=2000&auto=format&fit=crop'); background-size: cover; background-position: center;">
      <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.4);"></div>
      <div style="position: relative; z-index: 10; text-align: center; color: white; padding: 0 24px;">
        <h1 style="font-size: 5rem; font-weight: 700; margin-bottom: 32px; text-shadow: 0 4px 20px rgba(0,0,0,0.5);">Explore Fall</h1>
        <a href="/fall-foliage-map" style="display: inline-block; background: white; color: #333; text-decoration: none; padding: 16px 32px; font-size: 1rem; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
          Find Foliage Near You
        </a>
      </div>
    </div>

    {/* EXPLORE BY STATE */}
    <div style="max-width: 1200px; margin: 0 auto; padding: 96px 24px;">
      <div class="content-section reverse">
        <div style="flex: 1; display: flex; align-items: center; justify-content: center; height: 500px; position: relative;">
          <FoliageMap client:load center={[39.8283, -98.5795]} initialZoom={3} statesGeoJSON={usStates} />
        </div>
        <div class="content-text">
          <h2 style="font-size: 3rem; color: #111; margin-bottom: 24px;">Explore by State</h2>
          <p style="font-size: 1.1rem; color: #555; line-height: 1.8; margin-bottom: 32px;">
            Looking for a fall foliage map of your state? We provide daily-updated maps for every state in the Lower 48, along with information about how you can plan ahead for your fall color trip.
          </p>
          <a href="/locations" style="display: inline-block; background: #8B3A3A; color: white; text-decoration: none; padding: 16px 32px; font-weight: 600; letter-spacing: 1px; transition: background 0.2s;">
            &larr; CLICK A STATE
          </a>
        </div>
      </div>
    </div>

    {/* FALL FOLIAGE MAP PREVIEW */}
    <div style="background: #f8f9fa; padding: 96px 24px;">
      <div style="max-width: 1200px; margin: 0 auto;">
        <div class="content-section">
          <div class="content-image" style="background-image: url('/images/og-image.jpg'); background-size: cover; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.15);"></div>
          <div class="content-text">
            <h2 style="font-size: 3rem; color: #111; margin-bottom: 24px;">Fall Foliage Map</h2>
            <p style="font-size: 1.1rem; color: #555; line-height: 1.8; margin-bottom: 32px;">
              When is peak fall color, and where can I find it? Look no further than our 2026 Fall Foliage Map! Our daily updates and forecasts can help you plan a weekend trip with the family or simply seek out the best fall color 2026 has to offer.
            </p>
            <a href="/fall-foliage-map" style="color: #8B3A3A; font-weight: 600; text-decoration: none; font-size: 1.1rem; border-bottom: 2px solid #8B3A3A; padding-bottom: 4px;">
              View Live Map &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* EXPLORE BLOG PREVIEW */}
    <div style="max-width: 1200px; margin: 0 auto; padding: 96px 24px;">
      <div class="content-section reverse">
        <div class="content-image" style="background-image: url('https://images.unsplash.com/photo-1476820865390-c52aeebb9891?q=80&w=2000&auto=format&fit=crop'); background-size: cover; border-radius: 12px;"></div>
        <div class="content-text">
          <h2 style="font-size: 3rem; color: #111; margin-bottom: 24px;">Explore Fall Blog</h2>
          <p style="font-size: 1.1rem; color: #555; line-height: 1.8; margin-bottom: 32px;">
            Keep up with the latest fall color progression on our blog, updated throughout the week! Featuring weekly fall photo submissions and reports from across the country, you don't want to miss out on this unbe-leaf-able info!
          </p>
          <a href="/blog" style="display: inline-block; background: #8B3A3A; color: white; text-decoration: none; padding: 16px 32px; font-weight: 600; letter-spacing: 1px; transition: background 0.2s;">
            READ MORE
          </a>
        </div>
      </div>
    </div>

  </main>
</Layout>

<style>
  .content-section {
    display: flex;
    flex-direction: column;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 900px) {
    .content-section {
      flex-direction: row;
      gap: 80px;
    }
    .content-section.reverse {
      flex-direction: row-reverse;
    }
  }

  .content-image {
    width: 100%;
    height: 400px;
    flex: 1;
  }

  .content-text {
    flex: 1;
  }
</style>
