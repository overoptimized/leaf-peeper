---
import Layout from '../../layouts/Layout.astro';
import regionsData from '../../data/regions.json';

const title = "Popular Fall Foliage Regions Near Me | Leaf Peeper";
const description = "Discover the best regions and states for fall foliage across the country. Find peak color maps and leaf peeping reports near you.";

const popularStates = [
  { name: "Colorado", slug: "co", desc: "Famous for its stunning golden aspens contrasting against rugged mountain peaks.", img: "https://images.unsplash.com/photo-1476820865390-c52aeebb9891?q=80&w=600&auto=format&fit=crop" },
  { name: "Vermont", slug: "vt", desc: "The quintessential New England fall experience with endless rolling hills of red and orange maples.", img: "https://images.unsplash.com/photo-1507371341162-763b5e419408?q=80&w=600&auto=format&fit=crop" },
  { name: "Michigan", slug: "mi", desc: "Stunning lakeside drives and the incredible forests of the Upper Peninsula.", img: "https://images.unsplash.com/photo-1537225134706-e7e891eb9c9b?q=80&w=600&auto=format&fit=crop" },
  { name: "North Carolina", slug: "nc", desc: "Experience the sweeping vistas of the Blue Ridge Mountains glowing with autumn warmth.", img: "https://images.unsplash.com/photo-1541094052952-45e054bd58f0?q=80&w=600&auto=format&fit=crop" }
];
---

<Layout title={title} description={description} fullScreen={false}>
  <main style="max-width: 1200px; margin: 0 auto; padding: 100px 24px 64px 24px; min-height: 100vh;">
    
    <nav aria-label="breadcrumb" style="margin-bottom: 24px; font-size: 14px;">
      <ol style="list-style: none; padding: 0; margin: 0; display: flex; gap: 8px;">
        <li><a href="/" style="color: var(--text-secondary); text-decoration: none;">Home</a></li>
        <li style="color: var(--text-secondary);">/</li>
        <li style="color: var(--text-secondary);">Popular Regions</li>
      </ol>
    </nav>

    <h1 style="font-size: 3.5rem; margin: 0 0 16px 0; font-weight: 700; letter-spacing: -1px;">Popular Regions</h1>
    <p style="font-size: 1.2rem; color: var(--text-secondary); max-width: 800px; margin-bottom: 48px; line-height: 1.6;">
      Explore our curated collection of the most spectacular fall foliage regions across the country. Whether you're looking for a quick trip near you or planning an ultimate leaf-peeping road trip, find the perfect destination below.
    </p>

    <h2 style="font-size: 2rem; margin-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 12px;">Top Multi-State Regions</h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; margin-bottom: 64px;">
      {regionsData.map(region => (
        <a href={`/regions/${region.slug}`} class="glass-panel hover-card" style="display: flex; flex-direction: column; text-decoration: none; color: inherit; padding: 24px; transition: transform 0.2s, background 0.2s;">
          <h3 style="font-size: 1.5rem; margin: 0 0 12px 0; color: var(--text-primary);">{region.name}</h3>
          <p style="color: var(--text-secondary); line-height: 1.5; font-size: 14px; margin-bottom: 24px; flex: 1;">
            {region.description}
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 8px;">
            {region.states.map(state => (
              <span style="background: rgba(255,255,255,0.1); padding: 4px 8px; border-radius: 4px; font-size: 12px; text-transform: uppercase;">{state}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <h2 style="font-size: 2rem; margin-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 12px;">Top Fall Color States</h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
      {popularStates.map(state => (
        <a href={`/${state.slug}`} class="glass-panel hover-card" style="display: block; text-decoration: none; color: inherit; overflow: hidden; transition: transform 0.2s;">
          <div style={`height: 160px; background-image: url('${state.img}'); background-size: cover; background-position: center; position: relative;`}>
            <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);"></div>
            <h3 style="position: absolute; bottom: 16px; left: 16px; margin: 0; font-size: 1.5rem; color: #fff;">{state.name}</h3>
          </div>
          <div style="padding: 16px;">
            <p style="color: var(--text-secondary); line-height: 1.5; font-size: 14px; margin: 0;">
              {state.desc}
            </p>
          </div>
        </a>
      ))}
    </div>

  </main>
</Layout>

<style>
  .hover-card:hover {
    transform: translateY(-4px);
    background: rgba(30, 41, 59, 0.85);
  }
</style>
